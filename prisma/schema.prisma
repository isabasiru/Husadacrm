generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  AGENT
}

enum ConversationStatus {
  OPEN
  PENDING
  RESOLVED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  IMAGE
  DOCUMENT
  AUDIO
  INTERNAL_NOTE
}

enum WahaMessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

model User {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email           String    @unique @db.VarChar(255)
  passwordHash    String    @map("password_hash") @db.Text
  fullName        String    @map("full_name") @db.VarChar(255)
  role            Role
  avatarUrl       String?   @map("avatar_url") @db.Text
  whatsappNumber  String?   @map("whatsapp_number") @db.VarChar(20)
  isActive        Boolean   @default(true) @map("is_active")
  lastLoginAt     DateTime? @map("last_login_at") @db.Timestamp()
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp()
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp()

  // Relations
  assignedContacts      Contact[]        @relation("AssignedAgent")
  assignedConversations Conversation[]   @relation("AssignedAgentConv")
  repliedConversations  Conversation[]   @relation("LastRepliedBy")
  sentMessages          Message[]        @relation("SentByAgent")
  assignedFollowUps     FollowUp[]       @relation("AssignedAgentFollowUp")
  assignHistoryFrom     AssignHistory[]  @relation("AssignFromAgent")
  assignHistoryTo       AssignHistory[]  @relation("AssignToAgent")
  assignHistoryBy       AssignHistory[]  @relation("AssignedBy")
  activityLogs          ActivityLog[]

  @@map("users")
}

model Stage {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String    @unique @db.VarChar(100)
  color      String    @db.VarChar(7)
  orderIndex Int       @map("order_index")
  isDefault  Boolean   @default(false) @map("is_default")
  isTerminal Boolean   @default(false) @map("is_terminal")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamp()

  contacts   Contact[]

  @@map("stages")
}

model Tag {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique @db.VarChar(100)
  color       String   @db.VarChar(7)
  createdById String?  @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp()

  contacts ContactTag[]

  @@map("tags")
}

model ContactTag {
  contactId String  @map("contact_id") @db.Uuid
  tagId     String  @map("tag_id") @db.Uuid

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@map("contact_tags")
}

model Contact {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  whatsappNumber      String    @unique @map("whatsapp_number") @db.VarChar(20)
  fullName            String?   @map("full_name") @db.VarChar(255)
  age                 Int?
  domicile            String?   @db.VarChar(255)
  chiefComplaint      String?   @map("chief_complaint") @db.Text
  initialQuestion     String?   @map("initial_question") @db.Text
  medicalSupportData  String?   @map("medical_support_data") @db.Text
  currentMedications  String?   @map("current_medications") @db.Text
  stageId             String?   @map("stage_id") @db.Uuid
  assignedAgentId     String?   @map("assigned_agent_id") @db.Uuid
  interestedProductId String?   @map("interested_product_id") @db.Uuid
  chatbotState        String?   @map("chatbot_state") @db.VarChar(50)
  chatbotData         Json?     @map("chatbot_data") @db.JsonB
  lastInteractionAt   DateTime? @map("last_interaction_at") @db.Timestamp()
  totalMessages       Int       @default(0) @map("total_messages")
  notes               String?   @db.Text
  source              String    @default("whatsapp") @db.VarChar(50)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamp()
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp()

  // Relations
  stage             Stage?                @relation(fields: [stageId], references: [id])
  assignedAgent     User?                 @relation("AssignedAgent", fields: [assignedAgentId], references: [id])
  interestedProduct Product?              @relation(fields: [interestedProductId], references: [id])
  conversations     Conversation[]
  tags              ContactTag[]
  followUps         FollowUp[]
  customFields      ContactCustomField[]
  assignHistory     AssignHistory[]

  @@index([whatsappNumber])
  @@index([stageId])
  @@index([assignedAgentId])
  @@map("contacts")
}

model Conversation {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contactId        String             @map("contact_id") @db.Uuid
  wahaSession      String             @map("waha_session") @db.VarChar(100)
  status           ConversationStatus @default(OPEN)
  assignedAgentId  String?            @map("assigned_agent_id") @db.Uuid
  lastMessageAt    DateTime?          @map("last_message_at") @db.Timestamp()
  lastRepliedById  String?            @map("last_replied_by_id") @db.Uuid
  openedAt         DateTime           @default(now()) @map("opened_at") @db.Timestamp()
  resolvedAt       DateTime?          @map("resolved_at") @db.Timestamp()
  firstResponseAt  DateTime?          @map("first_response_at") @db.Timestamp()

  // Relations
  contact       Contact   @relation(fields: [contactId], references: [id])
  assignedAgent User?     @relation("AssignedAgentConv", fields: [assignedAgentId], references: [id])
  lastRepliedBy User?     @relation("LastRepliedBy", fields: [lastRepliedById], references: [id])
  messages      Message[]

  @@index([contactId])
  @@index([lastMessageAt])
  @@map("conversations")
}

model Message {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId  String             @map("conversation_id") @db.Uuid
  wahaMessageId   String?            @unique @map("waha_message_id") @db.VarChar(255)
  direction       MessageDirection
  type            MessageType        @default(TEXT)
  content         String?            @db.Text
  mediaUrl        String?            @map("media_url") @db.Text
  mediaMimeType   String?            @map("media_mime_type") @db.VarChar(100)
  sentById        String?            @map("sent_by_id") @db.Uuid
  isInternalNote  Boolean            @default(false) @map("is_internal_note")
  wahaStatus      WahaMessageStatus? @map("waha_status")
  sentAt          DateTime           @map("sent_at") @db.Timestamp()
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamp()

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sentBy       User?        @relation("SentByAgent", fields: [sentById], references: [id])

  @@index([conversationId])
  @@index([sentAt])
  @@map("messages")
}

model FollowUp {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contactId String    @map("contact_id") @db.Uuid
  agentId   String?   @map("agent_id") @db.Uuid
  dueAt     DateTime  @map("due_at") @db.Timestamp()
  note      String?   @db.Text
  status    String    @default("pending") @db.VarChar(50)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp()

  // Relations
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  agent   User?   @relation("AssignedAgentFollowUp", fields: [agentId], references: [id])

  @@map("follow_ups")
}

model CustomFieldDefinition {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(255)
  fieldKey  String   @unique @map("field_key") @db.VarChar(100)
  fieldType String   @map("field_type") @db.VarChar(50)
  options   Json?    @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp()

  @@map("custom_field_definitions")
}

model ContactCustomField {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contactId String   @map("contact_id") @db.Uuid
  fieldKey  String   @map("field_key") @db.VarChar(100)
  fieldValue String  @map("field_value") @db.Text
  fieldType String   @map("field_type") @db.VarChar(50)

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@map("contact_custom_fields")
}

model MessageTemplate {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @db.VarChar(255)
  category    String   @db.VarChar(100)
  content     String   @db.Text
  variables   Json?    @db.JsonB
  createdById String?  @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp()

  @@map("message_templates")
}

model AssignHistory {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contactId    String   @map("contact_id") @db.Uuid
  fromAgentId  String?  @map("from_agent_id") @db.Uuid
  toAgentId    String   @map("to_agent_id") @db.Uuid
  assignedById String?  @map("assigned_by_id") @db.Uuid
  assignedAt   DateTime @default(now()) @map("assigned_at") @db.Timestamp()

  // Relations
  contact    Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  fromAgent  User?   @relation("AssignFromAgent", fields: [fromAgentId], references: [id])
  toAgent    User    @relation("AssignToAgent", fields: [toAgentId], references: [id])
  assignedBy User?   @relation("AssignedBy", fields: [assignedById], references: [id])

  @@index([contactId])
  @@map("assign_history")
}

model ActivityLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(255)
  entityType String   @map("entity_type") @db.VarChar(100)
  entityId   String?  @map("entity_id") @db.Uuid
  metadata   Json?    @db.JsonB
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp()

  // Relations
  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@map("activity_logs")
}

model WahaSession {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionName String   @unique @map("session_name") @db.VarChar(100)
  phoneNumber String?  @map("phone_number") @db.VarChar(20)
  status      String   @default("disconnected") @db.VarChar(50)
  webhookUrl  String?  @map("webhook_url") @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp()
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp()

  @@map("waha_sessions")
}

model SystemSetting {
  key       String   @id @db.VarChar(100)
  value     String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp()

  @@map("system_settings")
}

model Product {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String    @db.VarChar(255)
  description String?   @db.Text
  category    String?   @db.VarChar(100)
  isActive    Boolean   @default(true) @map("is_active")
  sortOrder   Int       @default(0) @map("sort_order")
  parentId    String?   @map("parent_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp()
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp()

  // Self relation for parent-child products
  parent      Product?   @relation("ProductHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  subProducts Product[]  @relation("ProductHierarchy")
  contacts    Contact[]

  @@map("products")
}

